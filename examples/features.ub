# Ultimate Basic - Uj funkciok bemutato
# const, label/goto, poke/peek, rnd, abs, min, max, sgn

# Konstansok
const _BORDER = $D020
const _BG = $D021
const _RASTER = $D012

# Valtozok
var x = 20
var y = 12
var score = 0
var _color = 1
var dx = 0
var dy = 0
var sg = 0

cls
color text 14
color border 6
color bg 6
print "  ULTIMATE BASIC DEMO"
print "  =================="
print ""
print "  PRESS A KEY!"
print "  Q = QUIT"
print "  SPACE = SCORE + RANDOM COLOR"
print "  1-5 = BACKGROUND COLOR"
print ""

label main_loop

  # Billentyu lekerdezese getch-vel
  var key = getch()

  # Q = kilepes (kis q = 17, nagy Q = 81)
  if key == 81 then
    goto exit
  end

  if key == 17 then
    goto exit
  end

  # SPACE = pontszerzes + random szin
  if key == 32 then
    score = score + rnd()
    _color = rnd()
    _color = _color and 15
    poke _BORDER, _color
    print "  SCORE: ", score, "  COLOR: ", _color
  end

  # Szam billentyuk: hatter szin
  if key == 49 then
    poke _BORDER, 0
    print "  BACKGROUND: BLACK"
  end

  if key == 50 then
    poke _BORDER, 1
    print "  BACKGROUND: WHITE"
  end

  if key == 51 then
    poke _BG, 2
    print "  BACKGROUND: RED"
  end

  if key == 52 then
    poke _BG, 6
    print "  BACKGROUND: BLUE"
  end

  if key == 53 then
    poke _BG, 5
    print "  BACKGROUND: GREEN"
  end

  # abs() - tavolsag a kozep ponttol
  dx = abs(x - 20)
  dy = abs(y - 12)

  # min/max - hatarok
  x = min(x, 39)
  x = max(x, 0)

  # sgn() - irany
  sg = sgn(score)

  goto main_loop

label exit
  cls
  color border 6
  color bg 6
  color text 14
  print ""
  print "  GAME OVER!"
  print "  TOTAL SCORE: ", score
  print "  DISTANCE: dx=", dx, " dy=", dy
  print "  Sgn(score)=", sg
